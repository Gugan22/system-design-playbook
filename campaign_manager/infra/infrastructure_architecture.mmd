      COLD[("🧊 AWS S3 Glacier — Cold\nDeep Archive · Annual archival\n7yr compliance retention · aggregate data only\nAll data tokenized via TOKEN_REG\nGDPR erasure: revoke token in TOKEN_REG\nGlacier objects never retrieved for erasure\nAggregate retained unmodified · Art.17(3)(b)\nCost: no retrieval fee for erasure path\n[AWS Glacier]")]
    end

    FLINK --> PII_STRIP --> HOT
    FLINK --> MLGW
    MLGW --> ML_BUFFER
    ML_BUFFER -.->|"Drain on recovery"| MLGW
    HOT -.->|"Batch ETL every 6h"| WARM
    WARM -.->|"Annual archival"| COLD
  end

