flowchart TB

  %% =============================================
  %% LAYER 0 — GLOBAL NETWORK & SECURITY
  %% Owner: Infra/NetSec
  %% =============================================
  subgraph L0["🌐  LAYER 0 — Global Network & Security    [Owner: Infra/NetSec]"]
    direction LR

    subgraph L0_NET["  Global Edge Network  "]
      direction LR
      CDN["🌍 CDN / Anycast Router\nCloudFront / Fastly\nMulti-region PoPs\nDDoS L3/L4 absorption\n[Net-Svc]"]
      TLS["🔒 TLS Termination\nTLS 1.3 enforced\nCert rotation via ACM\nmTLS enforced service-to-service\n[Net-Svc]"]
      DDOS_L7["🔥 L7 DDoS Protection\nAWS Shield Advanced\nHTTP flood · Slowloris\nCredential stuffing mitigation\n[SecOps-Svc]"]
    end

    subgraph L0_SEC["  Security Controls  "]
      direction LR
      WAF_L7["🛡️ WAF L7\nOWASP ruleset · Rate-rule per IP\nGeo-blocking · Payload size limit\nTemplate injection prevention\n[SecOps-Svc]"]
      APIGW["🔌 API Gateway\nKong / AWS APIGW\nRoute versioning /v1 /v2\nDeprecation sunset enforcement\nPayload validation · Auth forwarding\n[Edge-Svc]"]
      API_LIFECYCLE["📋 API Lifecycle Manager\nVersion deprecation notices\nSunset date headers RFC 8594\nMigration guide per major version\nBreaking-change policy enforced\n[Edge-Svc]"]
      SECRETS["🔑 Secrets Manager\nVault / AWS Secrets Mgr\nAuto-rotation every 30d\nSidecar injection to ALL services\nService-to-service mTLS creds\n[SecOps-Svc]"]
      COMPLIANCE["⚖️ Compliance Gateway\nGDPR right-to-erasure\nCAN-SPAM opt-out\nDMARC / SPF / DKIM\nPII classifier\n[Legal-Svc]"]
    end

    subgraph L0_MESH["  Service Mesh  "]
      direction LR
      MESH["🕸️ Service Mesh\nIstio / Linkerd\nmTLS on all east-west traffic\nPer-service traffic policy\nInternal retries · timeouts\nCircuit break on internal calls\n[Infra-Svc]"]
    end

    subgraph L0_DEGRADE["  Degradation Contract  "]
      direction LR
      DEGRADE_POL["📉 Degradation Priority Policy\nTier 1: 2FA and transactional — never shed\nTier 2: Campaign sends — shed under load\nTier 3: Analytics — shed first\nTier 4: ML feedback — shed freely\nOwner: SRE enforces via DIST_QUOTA\n[SRE-Team]"]
    end

    subgraph L0_OPTOUT["  Unsubscribe Ingestion  "]
      direction LR
      OPTOUT_WH["📩 Unsubscribe Webhook Receiver\nHMAC-SHA256 per provider\nIP allowlist enforced\nIdempotency key per event\nOne-click RFC 8058\n[Compliance-Svc]"]
    end

    CDN --> TLS --> DDOS_L7 --> WAF_L7 --> APIGW
    APIGW --- API_LIFECYCLE
    OPTOUT_WH -->|"Verified opt-out events"| COMPLIANCE
  end

  %% =============================================
  %% LAYER 1 — INGRESS & IDENTITY
  %% Owner: Platform/Infra
  %% =============================================
  subgraph L1["🛡️  LAYER 1 — Global Edge & Ingress    [Owner: Platform/Infra]"]
    direction TB

    subgraph L1_ENTRY["  Entry Points  "]
      direction LR
      UI["🖥️ UI / Authoring\nDrag-and-drop builder\nTemplate versioning\n[Product-Svc]"]
      API["⚡ Developer API\nExternal integrations\nWebhook ingress\n[Edge-Svc]"]
    end

    subgraph L1_GATE["  Gatekeeper — all traffic passes through this chain  "]
      direction LR
      AUTH["🔐 OIDC / RBAC Auth\nJWT validation · Tenant authz\nToken refresh · MFA enforcement\n[Auth-Svc]"]
      TOKEN_REVOKE[("🚫 JWT Revocation Blocklist\nRedis-backed · TTL-aligned\nImmediate revoke on compromise\nAdmin offboard enforcement\n[Auth-Svc]")]
      CTX["🏷️ Tenant Context Injector\nStamps tenant ID on every request\nData isolation enforcement\n[Edge-Svc]"]
      CELL_ROUTER{"🔀 Cell Router\nRoutes by tenant cell\nPriority vs standard split\nL7 request inspection\n[Edge-Svc]"}
      DIST_QUOTA["🚦 Distributed Rate Limiter\nRedis-backed token bucket\nPer-tenant quota\nAutomated SRE backpressure\nThreshold: Kafka lag over 5M\nShed Tier 3 and 4 first per policy\n[Traffic-Svc]"]
    end

    subgraph L1_SUPPRESS["  Suppression  "]
      direction LR
      SUPPRESSION["🚫 Suppression Check\nUnsubscribe · blocklist\nHard bounce registry\nGDPR erasure enforcement\nFail-open with audit log on DB outage\n[Compliance-Svc]"]
      SUPPRESSION_DB[("📋 Suppression DB\nRedis bloom filter — hot layer\nPostgres — source of truth\nSync write: Redis first then Postgres\nRebuild from Postgres on Redis cold start\nMax stale tolerance: 30s\n[Compliance-Svc]")]
      FAST_SUPPRESS["🚫 Fast-Path Bloom Filter\nIn-memory suppression check\nFor 2FA hot path\nFalse-positive safe\n[Ingress-Svc]"]
    end

    FAST["🏎️ High-Priority Ingestor\nBypasses standard limiter\nFor 2FA and transactional alerts\nDedicated thread pool\n[Ingress-Svc]"]

    L1_ENTRY --> AUTH
    AUTH --> TOKEN_REVOKE --> CTX --> CELL_ROUTER
    CELL_ROUTER -->|"Standard traffic"| DIST_QUOTA
    CELL_ROUTER -->|"Priority: 2FA / Alerts"| FAST
    DIST_QUOTA --> SUPPRESSION
    SUPPRESSION <-->|"Lookup"| SUPPRESSION_DB
    FAST --> FAST_SUPPRESS
    FAST_SUPPRESS <-->|"Bloom filter lookup"| SUPPRESSION_DB
  end

  %% =============================================
  %% LAYER 2 — METADATA & IDENTITY
  %% Owner: Data-Platform
  %% =============================================
  subgraph L2["🧠  LAYER 2 — Metadata & Identity    [Owner: Data-Platform]"]
    direction TB

    subgraph L2_SOR["  System of Record (SoR)  "]
      direction LR
      WRITE_ADMIT["🚧 Write Admission Controller\nRejects writes when PgBouncer queue over 80%\nReturns 503 with Retry-After header\nPrevents silent timeout and retry storms\nEnables idempotent client retry\n[Data-Svc]"]
      PGBOUNCER["🔗 PgBouncer\nConnection pooler\nMax 10k client conns\nPrevents Postgres conn exhaustion\n[Data-Svc]"]
      CRM[("🗄️ Citus / Postgres CRM\nSharded by tenant_id · 32 shards\nRead replicas per region\nPITR backups every 1h\nWrite ceiling: 200k TPS via sharding\nHigh-freq events go to append store\n[CRM-Svc]")]
      APPEND_STORE[("⚡ Append-Only Event Store\nScyllaDB / DynamoDB\nHigh-frequency contact events\nOffloads CRM write path\nChange stream feeds APPEND_OUTBOX\nWrite: 500k+ TPS\n[Event-Store-Svc]")]
      OUTBOX["📤 CRM CDC Outbox\nDebezium · at-least-once\nTx-bound outbox table\nStreams CRM changes to Silver Lane\n[Data-Sync-Svc]"]
      APPEND_OUTBOX["📤 Append Store CDC\nChange stream connector\nStreams contact events to Silver Lane\nAt-least-once · schema-validated\n[Data-Sync-Svc]"]
      SCHEMA_REG[("📋 Schema Registry\nConfluent · RF=3 · clustered\nAvro / Protobuf enforcement\nBreaking-change prevention\nCached schemas in all producers\nAll producers must register\n[Schema-Svc]")]
      SCHEMA_MIG["🔧 Online Schema Migration\npt-online-schema-change / pgroll\nZero-downtime migrations\nRollback plan required per migration\n[Data-Svc]"]
    end

    subgraph L2_LOOKUP["  High-Concurrency Lookup  "]
      direction LR
      SLA_V{{"⏱️ Identity SLA Validator\nRejects if sync exceeds 50ms\nCompliance entities: hard reject on stale\nOffboarded tenants: hard reject on stale\nNon-critical: circuit-breaks to stale cache\nMax stale: 5 min for non-compliance paths\n[Identity-Svc]"}}
      IDMAP[("🗺️ Global ID Map\nRedis · 3-replica cluster\nTTL: 5 min · LRU eviction\nContact and tenant resolution\nSLA under 50ms\n[Identity-Svc]")]
    end

    subgraph L2_STATUS["  Campaign Status Store  "]
      direction LR
      STATUS_DB[("📊 Campaign Status DB\nPostgres · partitioned by tenant\nDurable authoritative state\nStatus: draft/running/done/failed\nDelivery counts per campaign\nQueried by campaign managers\n[Status-Svc]")]
    end

    subgraph L2_PII["  PII and Compliance  "]
      direction LR
      PII_MASK["🔏 PII Masking Layer\nTokenization at write\nField-level encryption\nAudit log on access\n[Privacy-Svc]"]
      ERASURE["🗑️ Erasure Processor\nGDPR right-to-delete\nPropagates to ALL tiers incl. COLD\nRate-limited: max 10k deletes/min\nDelete amplification protection\nSLA: 30d Hot/Warm · 90d Cold\n[Privacy-Svc]"]
    end

    ML_IN["🔁 ML Audience Feedback\nEngagement signals from L5\nUpdates segment scores\nAsync fire-and-forget\n[Async from Layer 5]"]

    WRITE_ADMIT --> PGBOUNCER --> CRM
    CRM --> OUTBOX
    APPEND_STORE --> APPEND_OUTBOX
    CRM -->|"Stream updates"| SLA_V --> IDMAP
    CRM <--> PII_MASK
    CRM <-->|"Schema-on-write"| SCHEMA_REG
    ERASURE -.->|"Rate-limited cascade"| CRM
    ERASURE -.->|"Rate-limited cascade"| APPEND_STORE
    ERASURE -.->|"Rate-limited cascade"| STATUS_DB
    ML_IN -.->|"Async segment tuning"| CRM
    OUTBOX <-->|"Schema validation"| SCHEMA_REG
    APPEND_OUTBOX <-->|"Schema validation"| SCHEMA_REG
    SCHEMA_MIG -.->|"Online migration"| CRM
  end

  %% =============================================
  %% LAYER 3 — THE HIGHWAY (EVENT BUS)
  %% Owner: Messaging-Infra
  %% =============================================
  subgraph L3["📡  LAYER 3 — The Highway (Event Bus)    [Owner: Messaging-Infra]"]
    direction TB

    subgraph L3_AUTH["  Topic Authorization  "]
      direction LR
      KAFKA_ACL["🔐 Kafka ACL / Authorization\nPer-topic ACL per service-account\nProducer scope: write-only\nConsumer scope: read-only\nTenant-ID header required in envelope\nConsumers validate tenant header\n[Kafka-Security-Svc]"]
    end

    subgraph L3_LANES["  Traffic Lanes  "]
      direction LR
      GOLD["🥇 Gold Lane\nKafka · RF=3 · 120 partitions\nRetention: 72h · ISR=2\nMsg envelope: tenant-id header\nSpill trigger: broker disk over 70%\nLag alert: over 50k msgs page SRE\nLow-latency · time-critical\n[Kafka-Cluster-A]"]
      SILVER["🥈 Silver Lane\nKafka · RF=3 · 600 partitions\nRetention: 7d · ISR=2\nMsg envelope: tenant-id header\nSpill trigger: consumer lag over 1M\nLag alert: over 5M msgs page SRE\nHigh-throughput · bulk\n[Kafka-Cluster-B]"]
    end

    subgraph L3_RESILIENCE["  Backpressure, Overflow and Recovery  "]
      direction LR
      GOLD_SPILL[("🥇☁️ Gold S3 Overflow\nSpill on Gold Lane saturation\nRetention: 72h · Re-entry to Gold\nPrevents Gold message loss\n[Storage-Svc]")]
      SPILL[("☁️ Silver S3 / Iceberg Overflow\nSpill SLA: re-entry under 15min\nPartitioned by tenant and hour\nPrevents Kafka lag cascade\n[Storage-Svc]")]
      REHYDRATE["💧 Hydration Worker\nThrottled re-entry\n500 msg/s max per tenant\nPrevents re-flood\n[Recovery-Svc]"]
      DLQ["🏥 Dead Letter Queue\nTTL: 7 days\nAuto-replay after 30min\nMax 3 retries then page SRE\nDepth alert over 1000\n[Recovery-Svc]"]
      REPLAY["▶️ DLQ Replay Service\nScheduled and manual trigger\nIdempotent re-injection\nGlobal replay rate cap: 5k msg/s total\nPer-tenant replay cap: 200 msg/s\nGold failures go to Gold Lane\nSilver failures go to Silver Lane\nRoot-cause gate: SRE must clear\nAudit trail per replay\n[Recovery-Svc]"]
    end

    GOLD -->|"Saturation spill"| GOLD_SPILL
    GOLD_SPILL -->|"Re-entry to Gold"| GOLD
    SILVER -->|"Congestion spill"| SPILL
    SPILL -->|"Throttled re-entry"| REHYDRATE --> SILVER
    DLQ --> REPLAY
    REPLAY -->|"Gold priority re-inject"| GOLD
    REPLAY -->|"Silver bulk re-inject"| SILVER
    KAFKA_ACL -.->|"Enforces on"| GOLD
    KAFKA_ACL -.->|"Enforces on"| SILVER
  end

  %% =============================================
  %% LAYER 4 — THE MUSCLE (EXECUTION ENGINE)
  %% Owner: Delivery-Eng
  %% =============================================
  subgraph L4["🚀  LAYER 4 — The Muscle (Execution Engine)    [Owner: Delivery-Eng]"]
    direction TB

    subgraph L4_ORCH["  Orchestration  "]
      direction LR
      SAGA["🎼 Saga Orchestrator\nMulti-step campaign flows\nCompensating transactions\nState per message in Redis-State\nSaga TTL: 24h max lifetime\nIdempotent step execution\n[State-Svc]"]
      CHOREO["📨 Event Consumer\nBulk stateless workers\nHPA: 10 to 500 pods\nPartition-to-pod ratio: 1.2x max\nConsumer group rebalance\n[Bulk-Svc]"]
      SEND_SCHED["⏰ Send-Time Optimizer\nTimezone-aware scheduling\nStaggered burst: max N/s per tenant\nTenant-aware canary routing\nRoutes through CB and TB\nSend-window config per campaign\n[Schedule-Svc]"]
    end

    subgraph L4_STATE["  Resilient State — 3 Isolated Redis Clusters  "]
      direction LR
      LCACHE["⚡ Local LRU Cache\nIn-process sub-ms\nMax 10k entries per worker\nReduces Redis pressure\n[Worker-Node]"]
      REDIS_IDEM[("🔴 Redis — Idempotency\n3-shard · 3-replica · cross-AZ\nTTL: 24h dedup window\nFail-open on shard loss with audit log\nDuplicate risk bounded to shard keyspace\nIsolated failure domain\n[Cache-Idem-Svc]")]
      REDIS_STATE[("🟠 Redis — Delivery State\n3-shard · 3-replica · cross-AZ\nSaga step tracking\nOn region failover: rebuild from STATUS_DB\nIsolated failure domain\n[Cache-State-Svc]")]
      REDIS_RATE[("🟡 Redis — Rate / Token Buckets\n3-shard · 3-replica · cross-AZ\nPer-provider token buckets\nOn region failover: reset to conservative defaults\nIsolated failure domain\n[Cache-Rate-Svc]")]
    end

    subgraph L4_PROV["  Provider Capacity Management  "]
      direction LR
      PROV_BUDGET["📊 Provider Budget Manager\nTracks rate limits per provider per tenant\nPer-tenant fairness during mass failover\nFallback quota: 60% of primary limit\nCost alert: fallback spend over 2x primary\nPrevents single-tenant monopoly on fallback\n[Delivery-Svc]"]
    end

    subgraph L4_WORKERS["  Channel Delivery Workers  (HPA: auto-scaled)  "]
      direction LR
      WEMAIL["📧 Email Pool\nSES / SendGrid / Mailgun\nSecondary provider fallback\nFallback governed by PROV_BUDGET\nDKIM signing\n[Mail-Svc]"]
      WSMS["💬 SMS / WhatsApp\nTwilio / Vonage\nSecondary provider fallback\nFallback governed by PROV_BUDGET\nDelivery receipt loop\n[Comm-Svc]"]
      WPUSH["🔔 Push Notifications\nFCM / APNs\nToken refresh on 410\n[Notify-Svc]"]
      WSOCIAL["📱 Social Channels\nInstagram · Facebook\nLinkedIn · OAuth token mgmt\n[Social-Svc]"]
    end

    subgraph L4_FAULT["  Provider Protection and Delivery Assurance  "]
      direction LR
      CB["⚙️ Smart Circuit Breaker\nHalf-open probe every 30s\nFallback routed through PROV_BUDGET\nState: closed/open/half-open\n[Resiliency-Svc]"]
      TB["🪙 Token Bucket\nPer-provider rate limiting\nRetry with exponential backoff\nPerm-fail goes to DLQ\n[Traffic-Svc]"]
      RECEIPT["📬 Delivery Receipt Reconciler\nProvider webhook ingestion\nStatus: sent/delivered/bounced\nHard bounce feeds SUPPRESSION_DB\nUpdates STATUS_DB per campaign\nSLA: reconcile under 5min\n[Delivery-Svc]"]
      RECEIPT_SWEEP["🔍 Receipt Timeout Sweep\nScheduled every 10min\nFinds messages with no receipt over 15min\nQueries provider API for status\nForces reconcile or sends to DLQ\n[Delivery-Svc]"]
    end

    subgraph L4_DEPLOY["  Deployment Safety — All Critical Services  "]
      direction LR
      CANARY["🐦 Canary Controller\nTenant-aware routing — not global 5%\nSmall tenants only in first wave\nTraffic split: 5% then 25% then 100%\nAuto-rollback on error spike\nCovers schema registry deploys\n[Deploy-Svc]"]
      LOAD_TEST["🔬 Load Test Gate\nk6 / Gatling shadow traffic\nMust pass at 2x target TPS\nBlocks promotion to prod\nRun before each scale milestone\n[QE-Svc]"]
    end

    L4_ORCH --> LCACHE
    LCACHE --> REDIS_IDEM
    LCACHE --> REDIS_STATE
    LCACHE --> REDIS_RATE
    REDIS_STATE --> L4_WORKERS
    REDIS_IDEM -.->|"Dedup check — fail-open with audit"| L4_WORKERS
    REDIS_RATE --> TB
    SEND_SCHED --> CB
    PROV_BUDGET --> CB
    L4_WORKERS --> CB --> TB
    TB -->|"Retry / Success"| L4_WORKERS
    TB -->|"Circuit open / Perm-fail"| DLQ
    L4_WORKERS -->|"Provider webhooks"| RECEIPT
    RECEIPT_SWEEP -->|"Force-reconcile missing receipts"| RECEIPT
    RECEIPT_SWEEP -.->|"Unresolvable goes to DLQ"| DLQ
  end

  %% =============================================
  %% LAYER 5 — THE MEMORY (ANALYTICS)
  %% Owner: Analytics-Eng
  %% =============================================
  subgraph L5["📊  LAYER 5 — The Memory (Analytics and Intelligence)    [Owner: Analytics-Eng]"]
    direction TB

    subgraph L5_STREAM["  Stream Processing  "]
      direction LR
      FLINK["⚡ Flink Stream Processor\nExactly-once semantics\nWatermark: 30s late arrival\nCheckpoint every 60s to S3\nState backend: RocksDB incremental\nMax state size per job: 500GB\nCheckpoint timeout: 120s — alert if exceeded\nOffset recovery: replay from Kafka\nTenant-partitioned jobs\n[Stream-Svc]"]
      PII_STRIP["🔏 PII Anonymizer\nStrips PII before analytics write\nTokenized contact IDs only\nGDPR compliant\n[Privacy-Svc]"]
    end

    subgraph L5_STORE["  Storage Tiers  "]
      direction LR
      HOT[("🔥 ClickHouse — Hot Tier\n8-shard · RF=3\nMergeTree · TTL: 30 days\nTenant-partitioned\nWrite: 2M rows/s\nPost-region-failover: rebuild from WARM\n[Insight-DB]")]
      WARM[("❄️ S3 Iceberg — Warm Tier\nBatch ETL every 6h\nParquet · Z-order by tenant\nRetention: 2 years\nMulti-region inherently\n[Datalake]")]
      COLD[("🧊 Glacier — Cold Tier\nAnnual archival\nCompliance retention: 7 years\n[Archive-Svc]")]
    end

    subgraph L5_ML["  ML Intelligence  "]
      direction LR
      MLGW["🤖 ML Feedback Gateway\nFast-path from Flink\nModel: engagement scoring\nAsync to Layer 2 segments\n[ML-Svc]"]
      ML_BUFFER[("🗄️ ML Signal Buffer\nKafka topic · TTL 1h\nAbsorbs signals when ML-Svc down\nAlert if drop rate over 5% in 10min\nPrevents silent signal loss\n[ML-Svc]")]
    end

    FLINK --> PII_STRIP --> HOT
    FLINK --> MLGW
    MLGW --> ML_BUFFER
    ML_BUFFER -.->|"Drain when ML-Svc recovers"| MLGW
    HOT -.->|"Batch ETL every 6h"| WARM
    WARM -.->|"Annual archival"| COLD
  end

  %% =============================================
  %% LAYER 6 — OBSERVABILITY AND DR
  %% Owner: SRE-Team
  %% =============================================
  subgraph L6["📡  LAYER 6 — Observability and DR    [Owner: SRE-Team]"]
    direction TB

    subgraph L6_OBS["  Observability Stack  "]
      direction LR
      TRACE["🔍 Distributed Tracing\nJaeger / Tempo\nTail-based sampling: 100% errors\n1% sampled for healthy paths\nTrace-ID on every event\n[Observability-Svc]"]
      METRICS["📈 Metrics and Alerting\nPrometheus + Grafana\nKafka lag · error rates\nDLQ depth · latency p99\nProvider fallback cost rate\nReceipt timeout rate\n[Observability-Svc]"]
      LOGS["📋 Centralized Logging\nElastic / Loki\nStructured JSON logs\nCorrelated by trace-ID\n[Observability-Svc]"]
    end

    subgraph L6_SLA["  SLA Monitoring  "]
      direction LR
      MON{{"🟢 SLA Monitor\nKafka lag thresholds enforced\nCircuit states · DLQ depth over 1000\nWorker error rates · p99 latency\nProvider fallback rate and cost\nML drop rate · Receipt sweep misses\nFlink checkpoint latency\n[SRE-Team]"}}
      ALERT["🔔 Alert and Throttle\nPagerDuty escalation\nRunbook links in every alert\nAutomated backpressure to DIST_QUOTA\nThreshold-based — not manual\n[SRE-Team]"]
      RUNBOOK["📖 Runbooks\nDLQ overflow · Circuit reset\nKafka rebalance · Redis failover\nFlink offset recovery\nCRM migration rollback\nRedis cold-start rebuild sequence\nClickHouse rebuild from WARM\n[SRE-Team]"]
    end

    subgraph L6_DR["  Disaster Recovery  "]
      direction LR
      DR["🔄 Multi-Region DR\nActive-passive · 2 regions\nRPO: 1 hour · RTO: 15 min\nCross-region Kafka MirrorMaker 2\nRedis rebuilt from Postgres on failover\nRate buckets reset to conservative defaults\nClickHouse rebuilt from WARM tier\nAuto-failover via Route53\n[Infra-Svc]"]
      DR_DRILL["🧪 DR Drill Program\nFull failover drill: quarterly\nChaos injection: monthly\nGame day: bi-annually\nResults tracked in runbook\n[SRE-Team]"]
    end

    MON --> ALERT --> RUNBOOK
    DR_DRILL -.->|"Validates"| DR
  end

