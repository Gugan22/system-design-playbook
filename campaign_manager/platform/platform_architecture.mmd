%% 8. EXTERNAL CHANNEL PROVIDERS
%% =====================================================

subgraph CHANNEL_PROVIDERS["📡 External Channel Providers"]
    EMAIL["Email Provider"]
    SMS["SMS Provider"]
    WHATSAPP["WhatsApp Business API"]
    SOCIAL["Instagram / Facebook / LinkedIn APIs"]
    PUSH["Push Notification Service"]
end

PROVIDER_ADAPTER --> EMAIL
PROVIDER_ADAPTER --> SMS
PROVIDER_ADAPTER --> WHATSAPP
PROVIDER_ADAPTER --> SOCIAL
PROVIDER_ADAPTER --> PUSH


%% =====================================================
%% 9. STATUS INGESTION
%% =====================================================

subgraph STATUS_INGESTION["📥 Delivery Status Ingestion"]
    WEBHOOK["Webhook Gateway"]
    VALIDATOR["Signature Validator"]
    NORMALIZER["Status Normalizer"]
end

EMAIL --> WEBHOOK
SMS --> WEBHOOK
WHATSAPP --> WEBHOOK
SOCIAL --> WEBHOOK
PUSH --> WEBHOOK

WEBHOOK --> VALIDATOR --> NORMALIZER
NORMALIZER --> TOPIC_STATUS_RAW
TOPIC_STATUS_RAW --> KAFKA
KAFKA --> TOPIC_STATUS_NORM
TOPIC_STATUS_NORM --> DELIVERY_STORE


%% =====================================================
%% 10. TRACKING SYSTEM
%% =====================================================

subgraph TRACKING_LAYER["🔍 Tracking Layer"]
    REDIRECT["Click Redirect Service"]
    PIXEL["Open Tracking Pixel"]
end

REDIRECT --> TOPIC_ANALYTICS
PIXEL --> TOPIC_ANALYTICS


