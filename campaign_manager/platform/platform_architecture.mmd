%% 11. ANALYTICS & REPORTING
%% =====================================================

subgraph ANALYTICS_DOMAIN["📊 Analytics & Reporting"]
    STREAM_PROC["Stream Processor"]
    AGG_DB["Analytics Aggregation DB\n(Partitioned by tenant_id)"]
    REPORT_API["Reporting API"]
    INTELLIGENCE["Campaign Intelligence Engine"]
end

KAFKA --> STREAM_PROC
